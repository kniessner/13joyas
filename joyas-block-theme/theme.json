{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "gradients": [],
      "palette": [
        { "color": "#0A0A0A", "name": "Obsidian", "slug": "obsidian" },
        { "color": "#1C1C1C", "name": "Charcoal", "slug": "charcoal" },
        { "color": "#C9A96E", "name": "Gold", "slug": "gold" },
        { "color": "#F5F2EB", "name": "Linen", "slug": "linen" },
        { "color": "#FFFFFF", "name": "White", "slug": "white" },
        { "color": "#4A4A4A", "name": "Ash", "slug": "ash" },
        { "color": "#E8E4DB", "name": "Sand", "slug": "sand" },
        { "color": "#1A1A1A", "name": "Dark", "slug": "dark" },
        { "color": "#C0C0C0", "name": "Silver", "slug": "silver" }
      ]
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1280px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 4,
        "unit": "rem"
      },
      "spacingSizes": [
        { "name": "3XS", "size": "0.25rem", "slug": "3xs" },
        { "name": "2XS", "size": "0.5rem", "slug": "2xs" },
        { "name": "XS", "size": "0.75rem", "slug": "xs" },
        { "name": "S", "size": "1rem", "slug": "s" },
        { "name": "M", "size": "1.5rem", "slug": "m" },
        { "name": "L", "size": "2rem", "slug": "l" },
        { "name": "XL", "size": "3rem", "slug": "xl" },
        { "name": "2XL", "size": "4rem", "slug": "2xl" },
        { "name": "3XL", "size": "6rem", "slug": "3xl" },
        { "name": "4XL", "size": "8rem", "slug": "4xl" }
      ]
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
          "name": "System Sans-serif",
          "slug": "system-sans-serif"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "name": "System Serif",
          "slug": "system-serif"
        },
        {
          "fontFamily": "'Playfair Display', serif",
          "name": "Heading",
          "slug": "heading"
        },
        {
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
          "name": "Body",
          "slug": "body"
        },
        {
          "fontFamily": "'Cormorant Garamond', Georgia, serif",
          "name": "Accent",
          "slug": "accent"
        },
        {
          "fontFamily": "'Marcellus', serif",
          "name": "Marcellus",
          "slug": "marcellus"
        },
        {
          "fontFamily": "'Inter Tight', -apple-system, BlinkMacSystemFont, sans-serif",
          "name": "Inter Tight",
          "slug": "inter-tight"
        }
      ],
      "fontSizes": [
        { "name": "XS", "size": "0.75rem", "slug": "xs" },
        { "name": "S", "size": "0.875rem", "slug": "s" },
        { "name": "M", "size": "1rem", "slug": "m" },
        { "name": "L", "size": "1.25rem", "slug": "l" },
        { "name": "XL", "size": "1.5rem", "slug": "xl" },
        { "name": "2XL", "size": "2rem", "slug": "2xl" },
        { "name": "3XL", "size": "clamp(2rem, 5vw, 3.5rem)", "slug": "3xl" },
        { "name": "4XL", "size": "clamp(2.5rem, 6vw, 5rem)", "slug": "4xl" },
        { "name": "5XL", "size": "clamp(3rem, 8vw, 7rem)", "slug": "5xl" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--obsidian)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "400",
          "lineHeight": "1.15"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--gold)"
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)"
        }
      }
    }
  },
  "customTemplates": [
    {
      "name": "page-full-width",
      "title": "Full Width Page",
      "postTypes": ["page"]
    },
    {
      "name": "page-landing",
      "title": "Landing Page",
      "postTypes": ["page"]
    }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" },
    { "name": "contact-cta", "title": "Contact CTA", "area": "uncategorized" },
    { "name": "process-steps", "title": "Process Steps", "area": "uncategorized" }
  ]
}
