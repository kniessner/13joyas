{
  "name": "joyas-block-theme",
  "version": "0.1.0",
  "description": "A modern block theme for Joyas.",
  "type": "module",
  "scripts": {
    "dev": "cd joyas-block-theme && vite",
    "build": "cd joyas-block-theme && vite build",
    "preview": "cd joyas-block-theme && vite preview",
    "lint:php": "composer lint",
    "fix:php": "composer fix",
    "analyze:php": "composer analyze",
    "lint:css": "stylelint 'joyas-block-theme/src/scss/**/*.scss'",
    "fix:css": "stylelint 'joyas-block-theme/src/scss/**/*.scss' --fix",
    "lint:ts": "tsc --noEmit",
    "format": "prettier --write '**/*.{ts,js,scss,css,json,md,yml,yaml}'",
    "format:check": "prettier --check '**/*.{ts,js,scss,css,json,md,yml,yaml}'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "theme:zip": "cd joyas-block-theme && npm run build && zip -r ../joyas-block-theme.zip . -x 'node_modules/*' '@kucrut/*' 'src/*' '.git/*' '*.log'",
    "start:dock": "cd docker && docker compose up -d",
    "stop:dock": "cd docker && docker compose down",
    "setup:wp": "chmod +x bin/wp-setup.sh && bin/wp-setup.sh",
    "setup:content": "chmod +x bin/wp-content-setup.sh && bin/wp-content-setup.sh",
    "setup:all": "npm run setup:wp && npm run setup:content",
    "prepare": "husky"
  },
  "devDependencies": {
    "@kucrut/vite-for-wp": "^0.11.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-links": "^10.4.0",
    "@storybook/html-vite": "^10.4.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@wordpress/interactivity": "^6.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0",
    "sass": "^1.80.0",
    "storybook": "^10.4.0",
    "stylelint": "^16.0.0",
    "stylelint-config-property-sort-order-smacss": "^10.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "terser": "^5.31.0",
    "typescript": "^5.6.0",
    "vite": "^6.2.0"
  },
  "lint-staged": {
    "*.scss": "stylelint --fix",
    "*.{ts,js,json,md,yml,yaml}": "prettier --write"
  },
  "optionalDependencies": {
    "@oxc-parser/binding-darwin-arm64": "0.127.0"
  }
}
