{
  "name": "joyas/joyas-block-theme",
  "description": "A modern block theme for Joyas.",
  "type": "project",
  "require": {},
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "squizlabs/php_codesniffer": "^3.11",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Joyas\\\\": "joyas-block-theme/includes/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=WordPress-Extra,WordPress-VIP-Go joyas-block-theme/functions.php joyas-block-theme/patterns joyas-block-theme/blocks joyas-block-theme/templates",
    "fix": "phpcbf --standard=WordPress-Extra,WordPress-VIP-Go joyas-block-theme/functions.php joyas-block-theme/patterns joyas-block-theme/blocks joyas-block-theme/templates",
    "analyze": "phpstan analyse --configuration=phpstan.neon"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
